# Copy to .env and fill in. With no .env the agent runs fully offline on SQLite
# + a deterministic mock reasoner.

# --- Reasoner (LLM) -----------------------------------------------------------
# Provider is inferred: if OPENROUTER_API_KEY is set, the OpenAI-compatible path
# is used (any model on OpenRouter). Else ANTHROPIC_API_KEY (native Claude).
# Else the offline mock.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
# Base URL for the OpenAI-compatible endpoint (OpenRouter by default).
BENTLYK_LLM_BASE_URL=https://openrouter.ai/api/v1
# Chat model. For OpenRouter use slugs like "anthropic/claude-3.5-sonnet",
# "openai/gpt-4o", "google/gemini-2.0-flash-001", etc.
BENTLYK_MODEL=anthropic/claude-3.5-sonnet
# Optional separate (often stronger) model for the nightly reflection pass.
BENTLYK_REFLECTION_MODEL=

# --- Storage ------------------------------------------------------------------
# sqlite (default, zero-setup) or postgres (serverless / production).
# If BENTLYK_PG_DSN is set, postgres is selected automatically.
BENTLYK_STORE=sqlite
BENTLYK_SQLITE_PATH=./bentlyk.db
# Supabase connection string (use the connection pooler for serverless).
BENTLYK_PG_DSN=

# --- Behaviour ----------------------------------------------------------------
# Autonomy ceiling: observe | suggest | safe_act | escalated_act
BENTLYK_MAX_AUTONOMY=suggest
BENTLYK_IDENTITY=default

# --- Telegram -----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Lock the bot to one Telegram user id. If empty, the first chatter is claimed
# as owner and remembered.
TELEGRAM_ALLOWED_USER_ID=
# Shared secret Telegram echoes back so only it can call the webhook.
TELEGRAM_WEBHOOK_SECRET=
# Public channel Bentlyk posts to after your approval (id like -100123... or @name).
# The bot must be an admin of the channel.
TELEGRAM_CHANNEL_ID=

# --- Deploy (Vercel) ----------------------------------------------------------
# Protects /api/setup. Visit /api/setup?secret=... once to register the webhook.
SETUP_SECRET=
# Set by Vercel for cron auth; optional locally.
CRON_SECRET=
