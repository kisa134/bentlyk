# Copy to .env and fill in. Everything is optional: with no .env the agent runs
# fully offline on SQLite + a deterministic mock reasoner.

# --- Reasoner (LLM) -----------------------------------------------------------
# If unset, bentlyk uses a deterministic offline reasoner so the loop still runs.
ANTHROPIC_API_KEY=
# Model used by the planner/reasoner and reflection loop.
BENTLYK_MODEL=claude-sonnet-4-6
# A more capable model for the nightly reflection/sleep pass (optional).
BENTLYK_REFLECTION_MODEL=claude-opus-4-8

# --- Storage ------------------------------------------------------------------
# sqlite (default, zero-setup) or postgres (production, pgvector).
BENTLYK_STORE=sqlite
BENTLYK_SQLITE_PATH=./bentlyk.db
# Used only when BENTLYK_STORE=postgres
BENTLYK_PG_DSN=postgresql://localhost:5432/bentlyk

# --- Behaviour ----------------------------------------------------------------
# Starting autonomy ceiling: observe | suggest | safe_act | escalated_act
BENTLYK_MAX_AUTONOMY=suggest
# Identity profile to load on boot (see config/identity.*.json).
BENTLYK_IDENTITY=default

# --- Interfaces (optional) ----------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
