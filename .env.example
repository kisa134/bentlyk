# Copy to .env and fill in. With no .env the agent runs fully offline on SQLite
# + a deterministic mock reasoner.

# --- Reasoner (LLM) -----------------------------------------------------------
# OpenAI-compatible gateway. Defaults to WaveSpeed (https://llm.wavespeed.ai/v1)
# with a top Chinese chat model. WAVESPEED_API_KEY also works.
BENTLYK_LLM_API_KEY=
# Override base URL / models per role if needed:
BENTLYK_LLM_BASE_URL=
BENTLYK_MODEL=
BENTLYK_REASON_MODEL=
BENTLYK_REFLECTION_MODEL=
# Strong coding model for self-programming (default: qwen/qwen3-coder):
BENTLYK_CODE_MODEL=
BENTLYK_FALLBACK_MODEL=
# Native Anthropic (alternative to the OpenAI-compatible path):
ANTHROPIC_API_KEY=

# --- Web search ---------------------------------------------------------------
# Optional. Without a key, keyless DuckDuckGo is used. Set for higher-quality
# Tavily results.
BENTLYK_TAVILY_KEY=

# --- Storage ------------------------------------------------------------------
# sqlite (default, zero-setup) or postgres (serverless / production).
# If BENTLYK_PG_DSN is set, postgres is selected automatically.
BENTLYK_STORE=sqlite
BENTLYK_SQLITE_PATH=./bentlyk.db
# Supabase connection string (use the connection pooler for serverless).
BENTLYK_PG_DSN=

# --- Behaviour ----------------------------------------------------------------
# Autonomy ceiling: observe | suggest | safe_act | escalated_act
BENTLYK_MAX_AUTONOMY=suggest
BENTLYK_IDENTITY=default

# --- Telegram -----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Lock the bot to one Telegram user id. If empty, the first chatter is claimed
# as owner and remembered.
TELEGRAM_ALLOWED_USER_ID=
# Shared secret Telegram echoes back so only it can call the webhook.
TELEGRAM_WEBHOOK_SECRET=
# Public channel Bentlyk posts to after your approval (id like -100123... or @name).
# The bot must be an admin of the channel.
TELEGRAM_CHANNEL_ID=

# --- Self-authoring & embodiment ----------------------------------------------
# Fine-grained PAT with Contents:write on the self-repo, so Bentlyk can write
# and publish its own code (write_program / publish_site tools).
BENTLYK_GH_TOKEN=
BENTLYK_SELF_REPO=kisa134/bentlyk-self
# A persistent body (always-on machine) lives its own life: set autonomy to at
# least safe_act so pursue() can actually run its self-directed tools.
# Local sandbox for files/code + opt-in code execution (only on your own machine):
BENTLYK_WORKDIR=
BENTLYK_ALLOW_CODE=

# --- Deploy (Vercel) ----------------------------------------------------------
# Protects /api/setup. Visit /api/setup?secret=... once to register the webhook.
SETUP_SECRET=
# Set by Vercel for cron auth; optional locally.
CRON_SECRET=
